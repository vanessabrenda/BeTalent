                  "var jsonData = pm.response.json();\r",
                  "pm.test(\"Campos parciais atualizados\", function () {\r",
                  "    pm.expect(jsonData.firstname).to.eql(\"Teste\");\r",
                  "    pm.expect(jsonData.lastname).to.eql(\"Updateparcial\");\r",
