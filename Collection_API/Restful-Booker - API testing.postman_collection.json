                  "// Mantém os outros campos\r",
                  "pm.test(\"Outros campos permanecem\", function () {\r",
                  "    pm.expect(jsonData.totalprice).to.exist;\r",
                  "    pm.expect(jsonData.depositpaid).to.exist;\r",
                  "    pm.expect(jsonData.bookingdates.checkin).to.exist;\r",
                  "    pm.expect(jsonData.bookingdates.checkout).to.exist;\r",
                  "});"
