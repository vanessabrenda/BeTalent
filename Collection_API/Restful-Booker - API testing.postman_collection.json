          "name": "Booking - Update",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code é 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.headers.get(\"Content-Type\") === \"application/json\") {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Campos atualizados corretamente\", function () {\r",
                  "        pm.expect(jsonData.firstname).to.eql(\"Teste\");\r",
                  "        pm.expect(jsonData.lastname).to.eql(\"Update\");\r",
                  "        pm.expect(jsonData.totalprice).to.eql(112);\r",
                  "        pm.expect(jsonData.depositpaid).to.eql(true);\r",
                  "        pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-06-01\");\r",
                  "        pm.expect(jsonData.bookingdates.checkout).to.eql(\"2027-07-01\");\r",
                  "        pm.expect(jsonData.additionalneeds).to.eql(\"uma cama\");\r",
                  "    });\r",
                  "} else {\r",
                  "    console.log(\"Resposta não é JSON:\", pm.response.text());\r",
                  "}\r",
                  ""
